# Database Connection String (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/job-portal?retryWrites=true&w=majority

# Backend Configuration
PORT=5000
JWT_SECRET=your_jwt_secret_here

# Cloudinary Credentials
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend Configuration (Used at build time)
# For local Docker testing: http://localhost:5000
# For AWS deployment: The URL of your backend load balancer or App Runner service
VITE_BACKEND_URL=your_backend_url_here
